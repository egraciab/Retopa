<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>RETOPA Admin - Negocios</title>
  <style>
    body { font-family: Arial; margin: 20px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #ccc; padding: 6px; font-size: 13px; }
    .topbar { margin-bottom: 15px; }
  </style>
</head>
<body>

<div class="topbar">
  <strong id="userInfo"></strong>
  <a href="/admin/claims.html">Ver claims</a>
  <button id="logoutBtn">Salir</button>
</div>

<h1>Negocios</h1>

<a href="/admin/business-create.html">+ Nuevo negocio</a>
<input type="text" id="q" placeholder="Buscar nombre / dirección / RUC" />
<button onclick="loadBusinesses()">Buscar</button>

<select id="claimed">
  <option value="">Claimed</option>
  <option value="true">true</option>
  <option value="false">false</option>
</select>

<select id="active">
  <option value="">Activo</option>
  <option value="true">true</option>
  <option value="false">false</option>
</select>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Nombre</th>
      <th>RUC</th>
      <th>Ciudad</th>
      <th>Teléfono</th>
      <th>Email</th>
      <th>Categoría</th>
      <th>Source</th>
      <th>Claimed</th>
      <th>Activo</th>
    </tr>
  </thead>
  <tbody id="rows"></tbody>
</table>

<script src="/admin/js/config.js"></script>
<script src="/admin/js/auth.js"></script>

<script>
async function loadBusinesses() {
  const q = document.getElementById('q').value;
  const claimed = document.getElementById('claimed').value;
  const active = document.getElementById('active').value;

  const url = new URL(`${window.location.origin}${window.RETOPA_API_BASE}/admin/businesses`);

  if (q) url.searchParams.set('q', q);
  if (claimed) url.searchParams.set('claimed', claimed);
  if (active) url.searchParams.set('is_active', active);

  const res = await fetch(url, {
    headers: { ...authHeaders() }
  });

  const json = await res.json();

  const tbody = document.getElementById('rows');
  tbody.innerHTML = '';

  (json.data || []).forEach(b => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${b.id}</td>
      <td><a href="/admin/business-edit.html?id=${b.id}">${b.name}</a></td>
      <td>${b.ruc || ''}</td>
      <td>${b.city || ''}</td>
      <td>${b.phone || ''}</td>
      <td>${b.email || ''}</td>
      <td>${b.category || ''}</td>
      <td>${b.source || ''}</td>
      <td>${b.claimed}</td>
      <td>${b.is_active}</td>
    `;
    tbody.appendChild(tr);
  });
}

async function init() {
  const user = await requireSession();
  if (!user) return;

  document.getElementById('userInfo').textContent = `${user.full_name} (${user.role})`;
  loadBusinesses();
}

document.getElementById('logoutBtn').onclick = () => {
  clearToken();
  location.href = '/admin/login.html';
};

init();
</script>

</body>
</html>
