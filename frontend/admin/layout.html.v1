<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>RETOPA Admin</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body { background:#f4f6f9; }

.sidebar {
  width:220px;
  height:100vh;
  position:fixed;
  background:#343a40;
  color:white;
  padding:15px;
}

.sidebar a {
  color:#ddd;
  display:block;
  padding:8px;
  text-decoration:none;
}

.sidebar a:hover {
  background:#495057;
}

.content {
  margin-left:240px;
  padding:20px;
}
.card {
  border-radius:10px;
}
</style>

</head>

<body>

<div class="sidebar">
  <h4>RETOPA</h4>
  <a href="/admin/dashboard.html">Dashboard</a>
  <a href="/admin/businesses.html">Negocios</a>
  <a href="/admin/claims.html">Claims</a>
</div>

<div class="content" id="content">
</div>

</body>
</html>
